{
  "name": "secret-shuttle",
  "version": "0.1.1",
  "description": "Local-daemon CLI that lets AI coding agents use secrets without seeing them.",
  "homepage": "https://github.com/pdumicz/secret-shuttle",
  "repository": {
    "type": "git",
    "url": "https://github.com/pdumicz/secret-shuttle.git"
  },
  "type": "module",
  "bin": {
    "secret-shuttle": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.js.map",
    "!dist/**/*.tsbuildinfo",
    "SKILL.md",
    "skills/secret-shuttle/SKILL.md",
    "agents",
    "docs",
    "!docs/superpowers/**",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json && node -e \"import('node:fs').then(({copyFileSync,mkdirSync})=>{mkdirSync('dist/daemon/hub',{recursive:true});copyFileSync('src/daemon/approvals/ui.html','dist/daemon/approvals/ui.html');copyFileSync('src/daemon/approvals/unlock-ui.html','dist/daemon/approvals/unlock-ui.html');copyFileSync('src/daemon/approvals/session-ui.html','dist/daemon/approvals/session-ui.html');copyFileSync('src/daemon/hub/hub-ui.html','dist/daemon/hub/hub-ui.html');})\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && SECRET_SHUTTLE_NO_OPEN_URL=1 node --test \"dist/**/*.test.js\"",
    "check-pack": "npm run clean && npm run build && node scripts/check-pack.mjs",
    "prepack": "npm run clean && npm run build && node scripts/check-pack.mjs",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "keywords": [
    "ai",
    "secrets",
    "cli",
    "cdp",
    "local-first",
    "ai-agent",
    "claude",
    "cursor",
    "vault",
    "daemon"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "commander": "^12.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "jsdom": "^24.1.3",
    "typescript": "^5.8.3"
  }
}
